; GRC Assessment Platform - Custom NSIS installer text
; Only defines that electron-builder does NOT already set

; Welcome page
!define MUI_WELCOMEPAGE_TITLE "Welcome to GRC Assessment Platform"
!define MUI_WELCOMEPAGE_TEXT "This wizard will install GRC Assessment Platform.$\r$\n$\r$\nSupported compliance standards:$\r$\n  - ISO 27001:2022$\r$\n  - FedRAMP Moderate$\r$\n  - SOC 2$\r$\n  - NIST CSF 2.0$\r$\n  - PCI DSS v4.0$\r$\n  - HIPAA Security Rule$\r$\n  - FISMA High$\r$\n  - FISMA Moderate$\r$\n$\r$\nAll data is stored locally. No internet required for normal use."
